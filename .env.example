# Database Configuration (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_KEY=your_anon_key

# JWT Authentication
JWT_SECRET_KEY=change_this_to_a_random_secure_string

# Server Environment
ENVIRONMENT=development
PORT=8888

# Instagram / Facebook API Credentials (legacy fallback)
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
FACEBOOK_PAGE_ID=your_facebook_page_id

# Meta OAuth Setup
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
REDIRECT_URI=http://127.0.0.1:8888/auth/instagram/callback

# Facebook App Secret (used to validate webhook signatures)
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Webhook Verify Token
WEBHOOK_VERIFY_TOKEN=my_custom_verify_token_123
